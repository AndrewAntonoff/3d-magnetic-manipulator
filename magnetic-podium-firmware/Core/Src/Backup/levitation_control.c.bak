static CoilGeometry_t coil_geometry[NUM_COILS];

// Магнитное поле постоянного магнита (измерено без шара), единицы: µT
static const float B_permanent[5][3] = {
    {8014.5f, -1389.8f, -1.4f},
    {-178.1f, -17.1f, 8.8f},
    {-252.1f, 27.0f, -118.6f},
